{
  "name": "@overworld/analytics",
  "version": "0.1.0",
  "description": "Pluggable analytics providers (GA4, Clarity, console)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
