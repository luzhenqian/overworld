{
  "name": "@overworld/audio",
  "version": "0.9.0",
  "description": "BGM/SFX manager with scene-track mapping and autoplay policy handling",
  "keywords": [
    "overworld",
    "game",
    "rpg",
    "audio",
    "bgm",
    "sfx"
  ],
  "homepage": "https://github.com/NoahLu/overworld#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@overworld/core": "workspace:*"
  },
  "peerDependencies": {
    "zustand": "^5.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NoahLu/overworld.git",
    "directory": "packages/audio"
  }
}
